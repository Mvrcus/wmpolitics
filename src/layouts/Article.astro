---
import type { ArticleEntry } from '../lib/content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import StructuredData from '../components/StructuredData.astro';
import ArticleSidebar from '../components/ArticleSidebar.astro';
import { SITE_TITLE, SITE_URL } from '../consts';

interface Props {
	entry: ArticleEntry;
}

const { entry } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, category } = entry.data;
const slug = entry.id;
const articleUrl = new URL(`/updates/${slug}/`, SITE_URL).href;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} | ${SITE_TITLE}`} description={description} image={heroImage} />
		<StructuredData
			data={{
				'@context': 'https://schema.org',
				'@type': 'Article',
				headline: title,
				description,
				datePublished: pubDate.toISOString(),
				...(updatedDate && { dateModified: updatedDate.toISOString() }),
				url: articleUrl,
				publisher: { '@type': 'Organization', name: SITE_TITLE, url: SITE_URL },
			}}
		/>
	</head>
	<body>
		<Header />
		<main class="article-page article-page--with-sidebar">
			<div class="article-layout">
				<article>
					<header class="article-header">
						{category && <span class="category-label">{category}</span>}
						<h1>{title}</h1>
						<p class="article-meta">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<>
										{' '}
										· Updated <FormattedDate date={updatedDate} />
									</>
								)
							}
						</p>
					</header>
					{heroImage && (
						<figure class="hero-image">
							<img
								src={heroImage}
								alt={`Illustration for: ${title}`}
								width={1600}
								height={900}
								loading="eager"
								decoding="async"
							/>
						</figure>
					)}
					<div class="prose">
						<slot />
					</div>
				</article>
				<ArticleSidebar article={entry} />
			</div>
		</main>
		<Footer />
	</body>
</html>
