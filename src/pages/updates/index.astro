---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { SITE_TITLE } from '../../consts';
import { getLatestArticles } from '../../lib/content';

const posts = await getLatestArticles();
const title = `Updates | ${SITE_TITLE}`;
const description = 'Analysis and updates on West Michigan politics affecting Holland.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<h1>Updates</h1>
				<p class="hero-lead">Analysis on access, legislation, and local impact.</p>
			</header>

			<ul class="article-grid">
				{
					posts.map((post) => (
						<li>
							<ArticleCard article={post} />
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
