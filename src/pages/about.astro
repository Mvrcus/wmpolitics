---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const title = `About | ${SITE_TITLE}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-header">
				<h1>About West Michigan Politics</h1>
				<p class="hero-lead">{SITE_DESCRIPTION}</p>
			</header>

			<div class="prose">
				<h2>Mission</h2>
				<p>
					We focus on Holland and Ottawa County first, then the wider lakeshore region—helping
					residents understand who represents them and what their elected officials are doing in
					their name.
				</p>

				<h2>Editorial standards</h2>
				<ul>
					<li>
						<strong>Balance:</strong> Legislator profiles separate "what supporters highlight" from
						"what critics raise." We do not present one side as objective fact.
					</li>
					<li>
						<strong>Sources:</strong> Factual claims link to primary documents, official statements,
						or reputable local/national reporting. We correct errors when verified.
					</li>
					<li>
						<strong>Clarity:</strong> We avoid jargon where plain language works. When legislative
						text matters, we summarize impact for local readers.
					</li>
					<li>
						<strong>Independence:</strong> This site is not affiliated with any party, campaign, or
						officeholder. Profiles are research-based, not paid promotion.
					</li>
				</ul>

				<h2>What we are not</h2>
				<p>
					We are not a substitute for legal advice, official casework, or emergency services. For
					help with a federal agency, contact your representative's office directly. For voting
					districts and ballots, use Michigan's official voter tools.
				</p>

				<h2>Contact & corrections</h2>
				<p>
					Spotted an error or have a sourced addition? Use the newsletter signup on our homepage—we
					use it for occasional site updates and may follow up on substantive corrections.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
