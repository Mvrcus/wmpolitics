---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const path = pathname.endsWith('/') ? pathname : `${pathname}/`;
const isLegislatorsSection = path === '/legislators/' || path.startsWith('/legislators/');
---

<header class="site-header">
	<div class="header-top">
		<div class="header-brand">
			<a href="/" class="brand">{SITE_TITLE}</a>
			<p class="tagline">{SITE_DESCRIPTION}</p>
		</div>
		<button type="button" class="menu-toggle" aria-expanded="false" aria-controls="main-nav" data-menu-toggle>
			<span class="sr-only">Menu</span>
			<span class="bar"></span>
			<span class="bar"></span>
			<span class="bar"></span>
		</button>
	</div>
	<nav class="header-nav" id="main-nav" data-nav>
		<HeaderLink href="/">Home</HeaderLink>
		<HeaderLink href="/holland/">Holland</HeaderLink>
		<div class="nav-dropdown" data-nav-dropdown>
			<HeaderLink href="/legislators/" class:list={[{ 'nav-dropdown-trigger': true, active: isLegislatorsSection }]}>
				Legislators
			</HeaderLink>
			<ul class="nav-dropdown-menu" role="menu">
				<li role="none">
					<a href="/legislators/" role="menuitem" class:list={[{ active: path === '/legislators/' }]}>
						Current
					</a>
				</li>
				<li role="none">
					<a href="/legislators/past/" role="menuitem" class:list={[{ active: path.startsWith('/legislators/past/') }]}>
						Past
					</a>
				</li>
			</ul>
		</div>
		<HeaderLink href="/updates/">Updates</HeaderLink>
		<HeaderLink href="/about/">About</HeaderLink>
	</nav>
</header>

<script>
	const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
	const nav = document.querySelector<HTMLElement>('[data-nav]');

	toggle?.addEventListener('click', () => {
		const open = nav?.classList.toggle('open');
		toggle.setAttribute('aria-expanded', String(!!open));
	});
</script>

<style>
	.site-header {
		background: var(--color-white);
		border-bottom: 2px solid var(--color-black);
		position: sticky;
		top: 0;
		z-index: 100;
	}

	.header-top {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 1.25rem var(--content-padding) 0.75rem;
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.header-brand {
		flex: 1;
		min-width: 0;
	}

	.brand {
		display: block;
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: clamp(1.5rem, 4vw, 2rem);
		color: var(--color-black) !important;
		text-decoration: none;
		line-height: 1.1;
		letter-spacing: -0.02em;
	}

	.brand:hover {
		color: var(--color-accent) !important;
	}

	.tagline {
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		color: var(--color-muted);
		margin: 0.35rem 0 0;
		line-height: 1.4;
		max-width: 36rem;
	}

	.header-nav {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 var(--content-padding) 0;
		display: flex;
		align-items: center;
		gap: 0;
		border-top: 1px solid var(--color-border);
	}

	.header-nav :global(a) {
		padding: 0.85rem 1.25rem;
		color: var(--color-black);
		text-decoration: none;
		font-family: var(--font-sans);
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border-bottom: 2px solid transparent;
		margin-bottom: -2px;
		transition: color 0.15s, border-color 0.15s;
	}

	.header-nav :global(a:first-child) {
		padding-left: 0;
	}

	.header-nav :global(a:hover),
	.header-nav :global(a.active) {
		color: var(--color-accent);
		border-bottom-color: var(--color-accent);
		background: none;
	}

	.nav-dropdown {
		position: relative;
	}

	.nav-dropdown-menu {
		display: none;
		position: absolute;
		top: 100%;
		left: 0;
		min-width: 11rem;
		margin: 0;
		padding: 0.35rem 0;
		list-style: none;
		background: var(--color-white);
		border: 2px solid var(--color-black);
		box-shadow: 0 4px 0 rgba(0, 0, 0, 0.08);
		z-index: 110;
	}

	.nav-dropdown:hover .nav-dropdown-menu,
	.nav-dropdown:focus-within .nav-dropdown-menu {
		display: block;
	}

	.nav-dropdown-menu a {
		display: block;
		padding: 0.65rem 1rem !important;
		margin-bottom: 0 !important;
		border-bottom: none !important;
		text-transform: none;
		letter-spacing: 0;
		font-weight: 600;
	}

	.nav-dropdown-menu a:hover,
	.nav-dropdown-menu a.active {
		color: var(--color-accent);
		background: var(--color-bg, #fafafa);
	}

	.menu-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		background: none;
		border: 2px solid var(--color-black);
		padding: 0.5rem;
		cursor: pointer;
		flex-shrink: 0;
	}

	.bar {
		display: block;
		width: 20px;
		height: 2px;
		background: var(--color-black);
	}

	@media (max-width: 720px) {
		.menu-toggle {
			display: flex;
		}

		.header-nav {
			display: none;
			flex-direction: column;
			align-items: stretch;
			padding: 0;
			border-top: none;
		}

		.header-nav.open {
			display: flex;
			border-top: 1px solid var(--color-border);
			padding-bottom: 0.5rem;
		}

		.header-nav :global(a) {
			padding: 0.85rem var(--content-padding);
			border-bottom: 1px solid var(--color-border);
			margin-bottom: 0;
		}

		.header-nav :global(a:first-child) {
			padding-left: var(--content-padding);
		}

		.nav-dropdown {
			display: flex;
			flex-direction: column;
		}

		.nav-dropdown-menu {
			display: block;
			position: static;
			border: none;
			box-shadow: none;
			padding: 0 0 0.5rem;
			background: transparent;
		}

		.nav-dropdown-menu a {
			padding-left: calc(var(--content-padding) + 1rem) !important;
			font-size: 0.75rem !important;
			border-bottom: 1px solid var(--color-border) !important;
		}

		.tagline {
			display: none;
		}
	}
</style>
