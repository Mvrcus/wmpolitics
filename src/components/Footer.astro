---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div class="footer-col footer-mission-col">
			<p class="footer-brand">{SITE_TITLE}</p>
			<p class="footer-mission">{SITE_DESCRIPTION}</p>
		</div>

		<div class="footer-col">
			<p class="footer-heading">Explore</p>
			<nav class="footer-links" aria-label="Site sections">
				<a href="/about/">About</a>
				<a href="/legislators/">Legislators</a>
				<a href="/holland/">Holland</a>
				<a href="/updates/">Updates</a>
			</nav>
		</div>

		<div class="footer-col">
			<p class="footer-heading">Subscribe</p>
			<p class="footer-note">
				Get new profiles and local policy breakdowns in your inbox.
			</p>
			<a href="/#newsletter" class="footer-cta">Sign up for updates</a>
		</div>

		<div class="footer-col">
			<p class="footer-heading">More</p>
			<nav class="footer-links" aria-label="Additional links">
				<a href="/rss.xml">RSS Feed</a>
				<a href="/sitemap-index.xml">Sitemap</a>
			</nav>
		</div>
	</div>

	<div class="footer-bottom">
		<p class="copyright">&copy; {year} {SITE_TITLE}. All rights reserved.</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--color-black);
		color: rgba(255, 255, 255, 0.85);
		padding: clamp(2.5rem, 5vw, 4rem) var(--content-padding) 2rem;
		margin-top: var(--section-gap);
	}

	.footer-inner {
		max-width: var(--max-width);
		margin: 0 auto 2.5rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}

	@media (min-width: 600px) {
		.footer-inner {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 960px) {
		.footer-inner {
			grid-template-columns: 1.5fr 1fr 1fr 1fr;
		}
	}

	.footer-brand {
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: 1.25rem;
		margin: 0 0 0.75rem;
		color: var(--color-white);
	}

	.footer-mission {
		font-size: 0.9375rem;
		line-height: 1.55;
		margin: 0;
		color: rgba(255, 255, 255, 0.7);
		max-width: 28rem;
	}

	.footer-heading {
		font-family: var(--font-sans);
		font-size: 0.6875rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin: 0 0 1rem;
		color: var(--color-white);
	}

	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.footer-links a {
		color: rgba(255, 255, 255, 0.75);
		text-decoration: none;
		font-size: 0.9375rem;
	}

	.footer-links a:hover {
		color: var(--color-white);
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.footer-note {
		font-size: 0.875rem;
		line-height: 1.5;
		color: rgba(255, 255, 255, 0.65);
		margin: 0 0 1rem;
	}

	.footer-cta {
		display: inline-block;
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-white) !important;
		text-decoration: none;
		border-bottom: 1px solid var(--color-accent);
		padding-bottom: 2px;
	}

	.footer-cta:hover {
		color: var(--color-accent) !important;
	}

	.footer-bottom {
		max-width: var(--max-width);
		margin: 0 auto;
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.15);
	}

	.copyright {
		font-size: 0.8125rem;
		color: rgba(255, 255, 255, 0.5);
		margin: 0;
	}
</style>
